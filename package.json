{
  "name": "field-guide",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Offline-first, self-contained photographer's field guides. Static-hostable (Cloudflare Pages).",
  "scripts": {
    "fetch": "node build/fetch.mjs",
    "sheet": "node build/sheet.mjs",
    "build": "node build/assemble.mjs",
    "verify": "node build/verify.mjs",
    "dev": "node build/assemble.mjs && node -e \"console.log('open dist/ in a browser')\"",
    "nuxt:dev": "nuxt dev",
    "nuxt:build": "nuxt build",
    "nuxt:generate": "nuxt generate",
    "nuxt:prepare": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "sharp": "^0.33.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@rollup/plugin-yaml": "^5.0.0",
    "nuxt": "^4.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.8"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
